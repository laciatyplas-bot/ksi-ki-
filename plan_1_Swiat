export type BookStatus = 'idea' | 'szkic' | 'pisanie' | 'gotowe' | 'opublikowane';

export interface EteruniverseBook {
  id: string;
  title: string;
  status: BookStatus;
  coverUrl?: string;
  description?: string;
}

export interface EteruniverseGate {
  id: string;
  number: string;
  name: string;
  theme: string;
  emoji: string;
  color: {
    hsl: string;
    gradient: string;
    badge: string;
    border: string;
  };
  books: EteruniverseBook[];
}


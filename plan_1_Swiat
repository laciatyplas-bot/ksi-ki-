export const getTotalBooks = () => {
  return ETERUNIVERSE_GATES.reduce((acc, gate) => acc + gate.books.length, 0);
};

export const getBooksByStatus = (status: BookStatus) => {
  return ETERUNIVERSE_GATES.flatMap(gate => 
    gate.books.filter(book => book.status === status)
  );
};
